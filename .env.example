# PostersPlus environment configuration
# Copy this file to .env and fill in your values.
# All variables are optional

# =============================================================================
# Server Side Keys (if not set, must be passed by users in URL as parameter)
# =============================================================================

# [Required] TMDB API key — fetches posters, logos, and metadata.
# Get one free at https://www.themoviedb.org/settings/api
TMDB_API_KEY=

# [Required] MDBList API key — fetches aggregated ratings and keywords.
# Get one free at https://mdblist.com/
MDBLIST_API_KEY=

# Optional second MDBList API key. When the primary key is rate-limited,
# PostersPlus automatically rotates to this key and back, so ratings
# remain available even during peak usage.
MDBLIST_API_KEY_2=

# =============================================================================
# Access control
# =============================================================================

# Shared secret appended to every request as ?access_key=<value>.
# Leave blank to allow unauthenticated access.
ACCESS_KEY=

# =============================================================================
# Server
# =============================================================================

# Number of Uvicorn worker processes. One worker avoids duplicate uncached work
# and shares one in-process render/rating coordination layer. Default: 1.
# When tuning OCR, keep WORKERS x TEXTLESS_DETECTION_CONCURRENCY at or below
# the available CPU core count.

WORKERS=1

# =============================================================================
# AIOStreams integration (quality badges)
# =============================================================================

# Base URL of your AIOStreams instance, e.g. http://aiostreams:3000 (bypass authelia, docker network) or https://aiostreams.example.com 
# Leave blank to disable quality badges.
AIOSTREAMS_URL=

# AIOStreams config uuid:password encoded as Base64, including the colon.
# A separate config is recommended for this integration.
AIOSTREAMS_AUTH=

# Quality backend: aiostreams (default) or scraper.
QUALITY_SOURCE=aiostreams

# Base URL of a standalone Stremio stream addon when QUALITY_SOURCE=scraper.
SCRAPER_URL=

# Release-based quality fallback (default true). When the quality source
# returns nothing — or none is configured — infer a conservative badge from
# the title's release status: aired TV/anime -> WEB 1080p, movies on
# digital/streaming -> WEB 1080p, physical release -> 1080p. Titles still in
# cinemas or unreleased get no badge. Overridable per request with
# ?quality_release_fallback=false.
QUALITY_RELEASE_FALLBACK=true

# "New Episode" sash (TV/anime): label template and recency window.
# {s} = season, {e} = episode. Examples: S{s}E{e} -> "S2E5", T{s}E{e} -> "T2E5".
# The sash only shows when the latest episode aired within the window.
# Per-request overrides: ?episode_format= and ?episode_max_age_days=
EPISODE_SASH_FORMAT=S{s}E{e}
EPISODE_SASH_MAX_AGE_DAYS=7

# Anime score boost: when a title is detected as anime (TMDB genre Animation +
# Japanese origin) and MyAnimeList has a rating, MAL gets this share of the
# weighted score (0 disables). Overridable per request with ?anime_mal_weight=
ANIME_MAL_WEIGHT=0.4

# Viewer region (ISO 3166-1) for movie release-date lookups: when TMDB has
# release dates for this country, Cinema/Streaming/Physical status is judged
# by those alone — so a title already on digital locally isn't marked "in
# cinemas" because of a later US date. Overridable per request with ?region=
RELEASE_REGION=MX

# IANA timezone used as "today" for all release-date comparisons (new-release
# sash, new-episode sash, release status). Prevents a UTC server from flipping
# dates hours before/after the viewer's local calendar day.
RELEASE_TZ=America/Mexico_City

# Metadata TTL (days) for TV shows still airing ("Returning Series"). Their
# last_episode_to_air changes weekly, and the new-episode sash needs it fresh.
# Ended shows and movies keep the regular 7-day TTL. 0 disables.
TMDB_METADATA_AIRING_CACHE_DURATION=1

# Days to cache quality data for titles older than 2 weeks.
# New titles always use a 1-day TTL. Increase to reduce AIOStreams traffic.
QUALITY_OLD_CACHE_DURATION=90

# Max concurrent background quality fetches.
# Caps burst load when many uncached titles appear at once.
# More checks still happen, they just wait in a queue.
QUALITY_BG_CONCURRENCY=5

# Maximum seconds to wait when wait_for_quality=true is requested.
QUALITY_WAIT_TIMEOUT=30

# Maximum concurrent outbound MDBList calls per worker.
MDBLIST_CONCURRENCY=3

# =============================================================================
# CDN / caching
# =============================================================================

# Adds Cache-Control: public, max-age=<N> to poster responses.
# Set to 0 to disable (default; recommended unless you're using a CDN).
CDN_CACHE_TTL=0

# JPEG output quality for composited posters (70–95). Higher = larger files.
# Default: 85. Raise to 92 for pixel-peepers; lower to 75 to reduce storage/bandwidth.
JPEG_QUALITY=85

# Seconds to keep a composited poster before re-rendering.
# Default: 604800 (7 days)
# Pruning happens automatically based on this value to avoid an ever-growing cache of dead content when users abandon configs
COMPOSITE_CACHE_TTL=604800

# Maximum composite poster cache entries. 0 = no cap (rely on TTL alone).
# I suggest setting this on a public instance, as a failsafe.
COMPOSITE_MAX_ENTRIES=0

# Disable composite poster caching entirely. Every request re-renders from
# scratch. Only use this during development — never in production.
# DISABLE_COMPOSITE_CACHE=true

# =============================================================================
# Logo rendering
# =============================================================================

# When a flat (single-colour) logo's average colour is too close to the poster
# background, recolour it (white / black / complementary accent) so it stays
# legible. Multi-colour and outline logos are never touched. Experimental and
# off by default while it's tested — it can mis-handle some logos. Set to true
# to enable. Default: false.
# LOGO_CONTRAST_RESCUE=false

# Logo fill-stretch: a slim logo whose clamped size leaves it looking lost is
# enlarged toward its size cap by up to this factor (one axis only). 1.0 = no
# enlargement. Only applies when stretching is enabled (see below). Default: 1.2.
# LOGO_STRETCH_FACTOR=1.2
# Fill-stretch is OFF by default (every logo kept at its true clamped size). Set
# to false to enable the stretch described above. Default: true.
# LOGO_STRETCH_DISABLED=true

# Emit per-logo sizing telemetry (source dims, aspect, final dims) at INFO level.
# Handy when tuning logo size; noisy in normal operation. Default: false.
# DEBUG_LOGO_SIZING=false

# Minimum votes preferred when selecting among TMDB textless posters. Candidates
# cannot be more than MAX_SCORE_DROP below the highest-rated textless option, so
# several negative votes cannot force selection of very poorly rated art.
# Defaults: 3 votes and a maximum 1.0-point downgrade.
# TMDB_POSTER_MIN_VOTES=3
# TMDB_POSTER_MAX_SCORE_DROP=1.0

# Ignore provider ratings with fewer votes than this. Roger Ebert is exempt
# because MDBList reports each review as one rating. Default: 10.
# RATING_MIN_VOTES=10

# Detect burned-in title text on posters TMDB mislabelled as "textless" and skip
# compositing our own logo so the title isn't doubled. Uses PP-OCRv5 Mobile;
# its ~4.6MB model is downloaded once into the cache volume. On by default;
# set to false to opt out. Default: true.
# TEXTLESS_TEXT_DETECTION=true
# Run burned-in-text detection in the foreground only for titles at or below
# this TMDB vote count. Higher-vote assets render immediately, are not cached as
# composites, and enter an idle background scan queue. Raise for more foreground
# accuracy; lower for faster stale-cache bursts. Default: 3000.
TEXTLESS_DETECTION_MAX_VOTES=3000
# Append OCR-rejected TMDB posters to a deduplicated human-review file at
# /app/cache/fake_textless_posters.txt. Default: true.
# TEXTLESS_FAKE_REPORT=true
# Optional custom path inside the container. Keep it under /app/cache to retain
# the report in the existing cache volume.
# TEXTLESS_FAKE_REPORT_PATH=/app/cache/fake_textless_posters.txt
# Minimum PP-OCR text-box confidence. Higher is stricter. Default: 0.70.
# PPOCR_BOX_THRESHOLD=0.70
# Lower-confidence fallback for wide, title-shaped regions. A box qualifies when
# it meets all three limits below. This catches stylised titles that PP-OCR scores
# around 0.30-0.69 without accepting the compact shapes in the Alien artwork.
# PPOCR_WIDE_BOX_THRESHOLD=0.30
# PPOCR_WIDE_MIN_ASPECT=3.0
# PPOCR_WIDE_MIN_AREA=0.01
# Minimum vertical centre for the poster-only geometric fallback used when OCR
# cannot read a centred, title-shaped box. Backdrop scans require title confirmation.
# PPOCR_WIDE_MIN_Y=0.55
# Independent PP-OCR sessions for parallel cold-cache scans. They use a dedicated
# executor and split available ONNX threads. Each extra session costs roughly
# 25-40MB with the bundled mobile model. Default 2 suits typical 3+ core hosts;
# use 1 on one- or two-core/memory-constrained hosts. Keep WORKERS x this value
# at or below available CPU cores. Capped at 4 and the detected CPU count.
# TEXTLESS_DETECTION_CONCURRENCY=2
# Fraction of poster height skipped from the TOP before counting title text.
# Titles can sit top/middle/bottom, so this scans almost the whole poster; the
# small default margin ignores studio/network bugs at the very edge. Raise it if
# top-edge logos cause false positives; 0 scans the entire poster. Default: 0.08.
# TEXTLESS_SCAN_TOP=0.08
# BUILD-TIME ONLY (read by compose at `docker compose build`): bake the ~4.6MB
# PP-OCRv5 Mobile model into the image. Set false to download it on first use.
# BAKE_PPOCR_MODEL=true

# =============================================================================
# Localisation
# =============================================================================

# ISO 639-1 language code for title logos (e.g. en, fr, de, ja).
# Falls back to English if the preferred language is unavailable.
# This can also be passed in the URL as a parameter (see web configurator)
DEFAULT_LOGO_LANGUAGE=en

# ===========================================================================
# ElfHosted fork — hosted-mode configuration (all opt-in; unset = upstream)
# ===========================================================================
# Storage backend (ElfHosted fork — hosted mode, opt-in)
# =============================================================================

# Leave DATABASE_URL unset to use SQLite (upstream default — recommended for
# private/single-user deployments). Set it to a postgresql:// URL to switch
# the cache layer to Postgres for multi-replica hosted deployments.
#   Example:  DATABASE_URL=postgresql://postersplus:secret@postgres:5432/postersplus
DATABASE_URL=
# Connection pool sizing (only used when DATABASE_URL is set).
DB_POOL_MIN_SIZE=1
DB_POOL_MAX_SIZE=10

# =============================================================================
# Coordination backend (ElfHosted fork — hosted mode, opt-in)
# =============================================================================

# Leave REDIS_URL unset to use in-process coordination (upstream default).
# Set it to a redis:// URL to share MDBList backoff + background-fetch claims
# across replicas. Render coalescing stays per-process either way.
#   Example:  REDIS_URL=redis://redis:6379/0
REDIS_URL=
# Prefix for Redis keys. Useful if multiple PostersPlus tenants share a
# single Redis instance and you want their keyspaces separated.
REDIS_KEY_PREFIX=postersplus

# =============================================================================
# Blob store backend (ElfHosted fork — hosted mode, opt-in)
# =============================================================================

# Leave OBJECT_STORE_URL unset to keep TMDB poster/logo bytes on the local
# filesystem (upstream default). Set to an s3:// URL to route them to an
# S3-compatible object store.
#   Example:  OBJECT_STORE_URL=s3://postersplus-cache?endpoint=https://s3.us-east-005.backblazeb2.com
#   Credentials come from standard AWS env vars (AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY)
#   or the pod's IAM role.
OBJECT_STORE_URL=
# Optional public CDN URL — when set, hosted-mode storage can issue 302
# redirects instead of proxying bytes through the app.
OBJECT_STORE_PUBLIC_URL=

# =============================================================================
# Render concurrency (ElfHosted fork — Phase 4)
# =============================================================================

# Maximum number of Pillow composite renders in flight at once. Each render
# pins one CPU core fully; this cap stops a burst from saturating every
# core and starving health probes. 0 = auto (os.cpu_count()).
RENDER_CONCURRENCY=0
# Seconds /poster will wait for a render slot before returning 503 with
# Retry-After. Set to 0 to never time out (wait forever). Default 30s.
RENDER_QUEUE_TIMEOUT=30

# =============================================================================
# Observability (ElfHosted fork — Phase 6)
# =============================================================================

# Optional shared secret guarding /metrics. Unset = open. Bind the app
# behind an ingress that gates /metrics if you don't want it public.
METRICS_ACCESS_KEY=
# Log output format: "text" (upstream default, human-readable) or "json"
# (one JSON object per line — for Loki / Elasticsearch / etc.).
LOG_FORMAT=text

# =============================================================================
# Per-tenant rate limit (ElfHosted fork — Phase 8)
# =============================================================================

# Maximum /poster requests per tenant per second. 0 = unlimited (upstream
# default). Tenant identity:
#   * If the user supplies tmdb_key=… or mdblist_key=… in URL params,
#     tenant = sha256(key)[:16].
#   * Otherwise tenant = "operator".
# When exceeded the request gets 429 with Retry-After: 1.
RATE_LIMIT_RPS=0

# =============================================================================
# Server
# =============================================================================

# Number of Uvicorn worker processes.
# Recommended: 1-2 for home use, up to (2 x CPU cores) for heavy load.
# Increase as required for large/public instances.

WORKERS=2

# =============================================================================
# AIOStreams integration (quality badges)
# =============================================================================

# Base URL of your AIOStreams instance, e.g. https://aiostreams.example.com
# Leave blank to disable quality badges.
AIOSTREAMS_URL=

# AIOStreams auth encoded as Base64, user:password
AIOSTREAMS_AUTH=

# Days to cache quality data for titles older than 2 weeks.
# New titles always use a 1-day TTL. Increase to reduce AIOStreams traffic.
QUALITY_OLD_CACHE_DURATION=90

# Max concurrent background quality fetches.
# Caps burst load when many uncached titles appear at once.
# More checks still happen, they just wait in a queue.
QUALITY_BG_CONCURRENCY=5

# =============================================================================
# CDN / caching
# =============================================================================

# Adds Cache-Control: public, max-age=<N> to poster responses.
# Set to 0 to disable (default; recommended unless you're using a CDN).
CDN_CACHE_TTL=0

# JPEG output quality for composited posters (70–95). Higher = larger files.
# Default: 85. Raise to 92 for pixel-peepers; lower to 75 to reduce storage/bandwidth.
JPEG_QUALITY=85

# Seconds to keep a composited poster before re-rendering.
# Default: 604800 (7 days)
# Pruning happens automatically based on this value to avoid an evergrowing cache of dead content when users abandon configs
COMPOSITE_CACHE_TTL=604800

# Maximum composite poster cache entries. 0 = no cap (rely on TTL alone).
# I suggest setting this on a public instance, as a failsafe.
COMPOSITE_MAX_ENTRIES=0

# =============================================================================
# Localisation
# =============================================================================

# ISO 639-1 language code for title logos (e.g. en, fr, de, ja).
# Falls back to English if the preferred language is unavailable.
# This can also be passed in the URL as a parameter (see web configurator)
DEFAULT_LOGO_LANGUAGE=en
